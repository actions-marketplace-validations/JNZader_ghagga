{
  "name": "ghagga-core",
  "version": "2.0.1",
  "private": false,
  "type": "module",
  "description": "Core review engine for GHAGGA — AI-powered multi-agent code reviewer",
  "author": "JNZader",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/JNZader/ghagga.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/JNZader/ghagga#readme",
  "bugs": {
    "url": "https://github.com/JNZader/ghagga/issues"
  },
  "keywords": [
    "ghagga",
    "code-review",
    "ai",
    "multi-agent",
    "llm",
    "static-analysis",
    "github"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:mutate": "stryker run",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^1.2.0",
    "@ai-sdk/google": "^1.2.0",
    "@ai-sdk/openai": "^1.3.0",
    "ghagga-db": "workspace:^",
    "ai": "^4.3.0",
    "minimatch": "^10.0.1",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@stryker-mutator/core": "^9.6.0",
    "@stryker-mutator/vitest-runner": "^9.6.0",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
