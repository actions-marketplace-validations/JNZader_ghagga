{
  "name": "ghagga-db",
  "version": "2.0.1",
  "private": false,
  "type": "module",
  "description": "Database layer for GHAGGA — AI-powered code reviewer",
  "author": "JNZader",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/JNZader/ghagga.git",
    "directory": "packages/db"
  },
  "homepage": "https://github.com/JNZader/ghagga#readme",
  "bugs": {
    "url": "https://github.com/JNZader/ghagga/issues"
  },
  "keywords": [
    "ghagga",
    "database",
    "drizzle",
    "code-review"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/migrate.ts",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "drizzle-orm": "^0.39.0",
    "pg": "^8.13.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
    "drizzle-kit": "^0.30.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
