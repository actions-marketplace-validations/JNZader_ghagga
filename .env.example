# ===========================================
# GHAGGA v2 - Environment Variables
# ===========================================
# Copy this file to .env and fill in your values

# --- Database ---
# PostgreSQL connection string (Neon, Supabase, or local)
DATABASE_URL=postgresql://user:password@host:5432/ghagga

# --- GitHub App ---
# Create a GitHub App: https://github.com/settings/apps/new
GITHUB_APP_ID=
GITHUB_PRIVATE_KEY=          # Base64-encoded .pem file content
GITHUB_WEBHOOK_SECRET=       # Secret configured in GitHub App webhook settings
GITHUB_CLIENT_ID=            # For OAuth login in dashboard
GITHUB_CLIENT_SECRET=        # For OAuth login in dashboard
STATE_SECRET=                # For CSRF protection in OAuth Web Flow (generate: openssl rand -hex 32)

# --- Inngest ---
# Sign up at https://www.inngest.com (free: 50k events/month)
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# --- Encryption ---
# 32-byte hex key for AES-256-GCM encryption of stored API keys
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# --- Server ---
PORT=3000
NODE_ENV=development

# --- Optional: Default LLM API Key (for repos without their own key) ---
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GOOGLE_AI_API_KEY=
