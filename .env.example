# =============================================================================
# GHAGGA v2 — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Legend:
#   [REQUIRED]  — Server will NOT start without this variable
#   [OPTIONAL]  — Has a sensible default or is only needed for specific features
#
# For local development, the minimum you need is:
#   DATABASE_URL, GITHUB_APP_ID, GITHUB_PRIVATE_KEY,
#   GITHUB_WEBHOOK_SECRET, ENCRYPTION_KEY
# =============================================================================

# ─── Database [REQUIRED] ────────────────────────────────────────────────────
# PostgreSQL connection string.
# Works with Neon, Supabase, Render, or local Docker.
# Format: postgresql://<user>:<password>@<host>:<port>/<database>
#
# For local Docker (docker compose up postgres -d):
DATABASE_URL=postgresql://ghagga:ghagga_dev@localhost:5432/ghagga

# ─── GitHub App [REQUIRED] ──────────────────────────────────────────────────
# Create a GitHub App: https://github.com/settings/apps/new
# Permissions needed: Pull Requests (read/write), Contents (read),
#                     Actions (read/write for runner dispatch)

# [REQUIRED] Numeric App ID — found on your GitHub App's settings page.
# Format: integer (e.g., 123456)
GITHUB_APP_ID=

# [REQUIRED] Private key for signing GitHub App JWTs.
# Format: Base64-encoded PEM file content (single line).
# Generate: base64 -w 0 < your-app.private-key.pem
# The original PEM file starts with "-----BEGIN RSA PRIVATE KEY-----"
# and is multi-line. Base64-encode it to store as a single env var.
GITHUB_PRIVATE_KEY=

# [REQUIRED] Webhook secret configured in your GitHub App settings.
# Format: arbitrary string (recommended: 40+ character random string).
# Generate: openssl rand -hex 20
# Must match exactly what you entered in the GitHub App webhook config.
GITHUB_WEBHOOK_SECRET=

# ─── GitHub OAuth (Dashboard login) [OPTIONAL] ──────────────────────────────
# Only needed if you're running the dashboard with GitHub OAuth login.
# Found in your GitHub App settings under "OAuth credentials".

# [OPTIONAL] OAuth Client ID for dashboard login.
# Format: string (e.g., "Iv1.abc123def456")
GITHUB_CLIENT_ID=

# [OPTIONAL] OAuth Client Secret for dashboard login.
# Format: 40-character hex string
GITHUB_CLIENT_SECRET=

# [OPTIONAL] Secret for CSRF protection in OAuth Web Flow.
# Format: 32-byte hex string (64 characters).
# Generate: openssl rand -hex 32
STATE_SECRET=

# ─── Inngest (Durable Functions) [OPTIONAL] ─────────────────────────────────
# Inngest provides durable, step-based review execution with retries.
# Sign up at: https://www.inngest.com (free tier: 50k events/month)
# Without Inngest, reviews still work but lack step-level checkpointing.

# [OPTIONAL] Event ingestion key.
# Format: string starting with "evt_" or similar Inngest format
INNGEST_EVENT_KEY=

# [OPTIONAL] Webhook signing key for verifying Inngest callbacks.
# Format: string starting with "signkey-" or similar Inngest format
INNGEST_SIGNING_KEY=

# ─── Encryption [REQUIRED] ──────────────────────────────────────────────────
# Used for AES-256-GCM encryption of stored API keys (BYOK model).
# Users' LLM API keys are encrypted at rest with this key.

# [REQUIRED] 32-byte hex key (64 hex characters).
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Example:  a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4e5f6a1b2
# WARNING:  Losing this key means all stored API keys become unrecoverable.
ENCRYPTION_KEY=

# ─── Server [OPTIONAL] ──────────────────────────────────────────────────────

# [OPTIONAL] Port the Hono server listens on.
# Format: integer (1024–65535)
# Default: 3000
PORT=3000

# [OPTIONAL] Node environment.
# Values: "development" or "production"
# Default: development
NODE_ENV=development

# [OPTIONAL] Runner callback secret time-to-live in minutes.
# How long to keep the per-dispatch HMAC secret before expiring it.
# Format: integer (minutes)
# Default: 11
# CALLBACK_TTL_MINUTES=11

# ─── Default LLM API Keys [OPTIONAL] ────────────────────────────────────────
# Fallback keys used when a repo doesn't have its own provider configured.
# Users can set per-repo keys in the dashboard — these are just defaults.
# Leave commented out if you don't want server-side default keys.

# [OPTIONAL] Anthropic API key.
# Format: string starting with "sk-ant-api03-"
# Get one: https://console.anthropic.com/
# ANTHROPIC_API_KEY=

# [OPTIONAL] OpenAI API key.
# Format: string starting with "sk-proj-" or "sk-"
# Get one: https://platform.openai.com/api-keys
# OPENAI_API_KEY=

# [OPTIONAL] Google AI (Gemini) API key.
# Format: string starting with "AIza"
# Get one: https://aistudio.google.com/apikey
# GOOGLE_AI_API_KEY=

# ─── CLI-Only Variables [OPTIONAL] ──────────────────────────────────────────
# These are only used by the `ghagga` CLI tool, not the server.

# [OPTIONAL] Memory backend for CLI.
# Values: "sqlite" (default, local file) or "engram" (HTTP API)
# GHAGGA_MEMORY_BACKEND=sqlite

# [OPTIONAL] Engram server URL (only used when GHAGGA_MEMORY_BACKEND=engram).
# Format: URL (e.g., http://localhost:7437)
# Default: http://localhost:7437
# GHAGGA_ENGRAM_HOST=http://localhost:7437

# [OPTIONAL] Engram connection timeout in seconds.
# Format: integer (seconds)
# Default: 5
# GHAGGA_ENGRAM_TIMEOUT=5
