{
  "name": "ghagga",
  "version": "2.3.0",
  "private": true,
  "description": "Multi-agent AI code reviewer for GitHub Pull Requests",
  "author": "JNZader",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@vitest/coverage-v8": "^3.0.0",
    "turbo": "^2.8.12"
  }
}
