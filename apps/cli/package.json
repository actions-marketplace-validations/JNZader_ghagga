{
  "name": "ghagga",
  "version": "2.5.0",
  "private": false,
  "type": "module",
  "description": "AI-powered code review from the command line — free with GitHub Models",
  "author": "JNZader",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/JNZader/ghagga.git",
    "directory": "apps/cli"
  },
  "homepage": "https://github.com/JNZader/ghagga#readme",
  "bugs": {
    "url": "https://github.com/JNZader/ghagga/issues"
  },
  "keywords": [
    "ghagga",
    "code-review",
    "ai",
    "cli",
    "github",
    "llm",
    "static-analysis",
    "multi-agent",
    "gpt",
    "developer-tools"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "bin": {
    "ghagga": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "chalk": "^5.6.0",
    "ghagga-core": "workspace:^",
    "commander": "^14.0.3",
    "dotenv": "^17.3.0"
  },
  "devDependencies": {
    "tsx": "^4.19.0",
    "typescript": "^5.9.0",
    "vitest": "^4.0.0",
    "@types/node": "^25.3.5"
  }
}
