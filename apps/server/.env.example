# ─── Database (Neon) ─────────────────────────────────────────────
# Get from: Neon Dashboard → Project → Connection Details → Connection String
DATABASE_URL=postgresql://neondb_owner:xxx@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# ─── Encryption Key ─────────────────────────────────────────────
# Used for AES-256-GCM encryption of user API keys.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# ─── GitHub App (SaaS mode) ─────────────────────────────────────
# Get from: GitHub → Settings → Developer settings → GitHub Apps → Your App
GITHUB_APP_ID=
GITHUB_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
GITHUB_WEBHOOK_SECRET=

# ─── Inngest (async review processing) ──────────────────────────
# Get from: Inngest Dashboard → Manage → Keys
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# ─── Server ─────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production
