    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@ghagga/core": "workspace:*",
    "@ghagga/db": "workspace:*",
    "hono": "^4.7.0",
    "@hono/node-server": "^1.13.0",
    "inngest": "^3.29.0",
    "@octokit/rest": "^21.1.0",
    "@octokit/webhooks": "^13.4.0",
    "dotenv": "^16.4.0"
  },
  "devDependencies": {
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0",
    "@types/node": "^22.0.0"
  }
}
