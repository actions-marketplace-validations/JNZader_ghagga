{
  "name": "@ghagga/server",
  "version": "2.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:mutate": "stryker run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.11",
    "@octokit/rest": "^21.1.0",
    "@octokit/webhooks": "^13.4.0",
    "dotenv": "^16.4.0",
    "ghagga-core": "workspace:*",
    "ghagga-db": "workspace:*",
    "hono": "^4.12.5",
    "hono-rate-limiter": "^0.5.3",
    "inngest": "^3.29.0",
    "libsodium-wrappers": "^0.7.15",
    "pino": "^10.3.1",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@stryker-mutator/core": "^9.6.0",
    "@stryker-mutator/vitest-runner": "^9.6.0",
    "@types/libsodium-wrappers": "^0.7.14",
    "@types/node": "^22.19.13",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
